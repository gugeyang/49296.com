# Hugo 编译输出目录（不上传，由 GitHub Actions 在云端生成）
public/

# Hugo 资源缓存
resources/_gen/
.hugo_build.lock

# 内部项目管理与商业机密文档（只留本地，不上传GitHub）
DEVELOPMENT_PLAN.md
CONTENT_MASTER_RECORD.md
REPLAY_OPTIMIZATION.md

# 操作系统临时文件
.DS_Store
Thumbs.db

# 编辑器配置
.vscode/settings.json
*.swp

# 仅忽略根目录下的 Markdown 文档和 Python 脚本，以确保 content/ 里的文章能正常上传
/*.md
/*.py
.env

